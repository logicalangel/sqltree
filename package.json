{
  "name": "sqltree",
  "version": "1.3.5",
  "description": "Interactive TUI database client for PostgreSQL and MySQL",
  "type": "module",
  "bin": {
    "sqltree": "bin/sqltree.js"
  },
  "main": "./src/app.js",
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/sqltree.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "database",
    "cli",
    "postgresql",
    "mysql",
    "terminal",
    "client",
    "tui",
    "sql",
    "tree"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logicalangel/sqltree.git"
  },
  "homepage": "https://github.com/logicalangel/sqltree",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.4.0",
    "mysql2": "^3.11.0",
    "neo-blessed": "^0.2.0",
    "ora": "^8.1.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.2",
    "vitest": "^4.1.2"
  }
}
