{
  "name": "sqltree",
  "version": "1.4.7",
  "description": "Interactive TUI database client for PostgreSQL, MySQL, and compatible databases",
  "type": "module",
  "bin": {
    "sqltree": "bin/sqltree.js"
  },
  "main": "./src/app.js",
  "exports": {
    ".": "./src/app.js",
    "./adapters": "./src/adapters/index.js"
  },
  "files": [
    "bin/",
    "src/"
  ],
  "scripts": {
    "start": "node bin/sqltree.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "database",
    "cli",
    "postgresql",
    "mysql",
    "mariadb",
    "cockroachdb",
    "redshift",
    "yugabytedb",
    "timescaledb",
    "supabase",
    "neon",
    "alloydb",
    "aurora",
    "tidb",
    "singlestore",
    "planetscale",
    "terminal",
    "client",
    "tui",
    "sql",
    "tree"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/logicalangel/sqltree.git"
  },
  "homepage": "https://github.com/logicalangel/sqltree",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "chalk": "^5.4.0",
    "mysql2": "^3.22.0",
    "neo-blessed": "^0.2.0",
    "ora": "^9.3.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.4"
  }
}
